{
  "name": "gympro-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node test/security-routes.smoke.js && node test/ownership-guards.smoke.js && node test/dietitian-slot.validation.smoke.js",
    "test:api": "vitest run",
    "test:api:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.js",
    "test:unit:watch": "vitest --config vitest.unit.config.js",
    "lint": "node ../node_modules/eslint/bin/eslint.js src",
    "lint:fix": "node ../node_modules/eslint/bin/eslint.js src --fix",
    "import:nutrition": "node scripts/importSriLankaFoods.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
